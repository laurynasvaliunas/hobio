{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (Metro — iOS/Android/Web)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "19007", "--no-dev"],
      "port": 19007
    },
    {
      "name": "Expo iOS Simulator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "Expo Android Emulator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    }
  ]
}
